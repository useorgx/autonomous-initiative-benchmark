{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/outreach-action-ledger.schema.json",
  "title": "OrgX-Bench SOTA Outreach Action Ledger",
  "description": "Auditable execution ledger for methodology, human-baseline, replication, and outside-reproduction outreach actions.",
  "type": "object",
  "required": [
    "ledger_version",
    "source_draft_package_version",
    "source_draft_generated_at",
    "generated_at",
    "summary",
    "actions"
  ],
  "additionalProperties": false,
  "properties": {
    "ledger_version": {
      "type": "string",
      "const": "sota_outreach_action_ledger_v1"
    },
    "source_draft_package_version": {
      "type": "string",
      "const": "sota_outreach_drafts_v1"
    },
    "source_draft_generated_at": { "type": "string" },
    "generated_at": { "type": "string" },
    "send_policy": { "type": "object" },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "planned",
        "completed",
        "blocked",
        "canceled",
        "recipient_facing",
        "due_now",
        "next_action_at",
        "next_follow_up_at"
      ],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "planned": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "canceled": { "type": "integer", "minimum": 0 },
        "recipient_facing": { "type": "integer", "minimum": 0 },
        "due_now": { "type": "integer", "minimum": 0 },
        "next_action_at": { "type": ["string", "null"] },
        "next_follow_up_at": { "type": ["string", "null"] }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": [
        "action_id",
        "draft_id",
        "target_id",
        "lane",
        "priority",
        "action_type",
        "status",
        "recipient_facing",
        "recommended_at",
        "message_sha256",
        "blocked_reasons",
        "execution_notes",
        "completed_at",
        "operator",
        "receipt",
        "follow_up_schedule",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "action_id": { "type": "string" },
        "draft_id": { "type": "string" },
        "target_id": { "type": "string" },
        "lane": { "type": "string" },
        "priority": { "type": "string" },
        "action_type": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["planned", "completed", "blocked", "replied", "declined", "scheduled", "canceled"]
        },
        "recipient_facing": { "type": "boolean" },
        "recommended_at": { "type": ["string", "null"] },
        "contact_method": { "type": ["string", "null"] },
        "contact_value": { "type": ["string", "null"] },
        "message_sha256": { "type": ["string", "null"] },
        "blocked_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution_notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completed_at": { "type": ["string", "null"] },
        "operator": { "type": ["string", "null"] },
        "receipt": {
          "type": ["object", "null"],
          "required": ["channel", "reference", "url"],
          "additionalProperties": false,
          "properties": {
            "channel": { "type": ["string", "null"] },
            "reference": { "type": ["string", "null"] },
            "url": { "type": ["string", "null"] }
          }
        },
        "follow_up_schedule": {
          "type": "array",
          "items": { "$ref": "#/$defs/follow_up" }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "follow_up": {
      "type": "object",
      "required": [
        "follow_up_id",
        "sequence",
        "business_days_after_completion",
        "due_at",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "follow_up_id": { "type": "string" },
        "sequence": { "type": "integer", "minimum": 1 },
        "business_days_after_completion": { "type": "integer", "minimum": 1 },
        "due_at": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "canceled"]
        }
      }
    }
  }
}
