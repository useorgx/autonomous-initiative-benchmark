{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/evaluation-manifest.schema.json",
  "title": "OrgX-Bench Evaluation Pre-Registration Manifest",
  "description": "Published before a benchmark run. The manifest binds the hypothesis, arms, model provenance, split, metrics, loss policy, and headline eligibility constraints before results are known.",
  "type": "object",
  "required": [
    "contractVersion",
    "id",
    "date",
    "claim",
    "arms",
    "tasks",
    "k",
    "metrics",
    "modelManifest",
    "lossPolicy",
    "lossRegistry",
    "headlineEligible"
  ],
  "additionalProperties": false,
  "properties": {
    "contractVersion": {
      "type": "string",
      "description": "Evaluation contract version, for example orgx-bench-v1.1."
    },
    "id": {
      "type": "string",
      "description": "Stable id; result bundles reference this value."
    },
    "date": {
      "type": "string",
      "description": "Pre-registration date in YYYY-MM-DD format, set before the run."
    },
    "claim": {
      "type": "string",
      "minLength": 20,
      "description": "The single falsifiable hypothesis this run tests."
    },
    "arms": {
      "type": "array",
      "minItems": 2,
      "description": "Named comparison arms. Vague labels such as Model A/B/C are forbidden.",
      "items": {
        "type": "object",
        "required": ["id", "system", "model"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "system": {
            "type": "string",
            "enum": [
              "single_frontier",
              "provider_native_agent",
              "best_of_n",
              "self_reflection",
              "static_orgx",
              "adaptive_orgx",
              "full_orgx",
              "fugu",
              "fugu_ultra"
            ]
          },
          "model": {
            "type": "string",
            "description": "Exact model id used by the arm."
          },
          "modelManifestId": {
            "type": "string",
            "description": "Optional explicit modelManifest.models[].id when it differs from model."
          },
          "provider": {
            "type": "string"
          },
          "scaffold": {
            "type": "string"
          },
          "budget": {
            "type": "object",
            "description": "Matched resource allowance for compute-matched controls.",
            "additionalProperties": false,
            "properties": {
              "dollars": {
                "type": ["number", "null"]
              },
              "tokens": {
                "type": ["number", "null"]
              },
              "calls": {
                "type": ["number", "null"]
              },
              "wallSeconds": {
                "type": ["number", "null"]
              }
            }
          }
        }
      }
    },
    "tasks": {
      "type": "string",
      "description": "Split or suite identifier, for example public_validation_worlds_v2 or private_holdout."
    },
    "k": {
      "type": "integer",
      "minimum": 1,
      "description": "Repeats per arm."
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "world_success_rate",
          "trust_adjusted_score",
          "pass_at_k",
          "pass_pow_k",
          "quality_per_ktoken",
          "cost_per_verified_outcome",
          "latency",
          "provenance_completeness",
          "recovery_score",
          "budget_adherence",
          "uncertainty_honesty",
          "qualified_work_product_success",
          "normalized_artifact_utility",
          "human_acceptance_rate",
          "perturbation_survival_rate",
          "horizon_50",
          "horizon_80",
          "gate_depth"
        ]
      }
    },
    "modelManifest": {
      "$ref": "model-manifest.schema.json"
    },
    "lossPolicy": {
      "type": "object",
      "required": [
        "publishAllAttempts",
        "singleAgentWinsAreLosses",
        "invalidRunsCountAsLosses"
      ],
      "additionalProperties": false,
      "properties": {
        "publishAllAttempts": {
          "type": "boolean",
          "const": true
        },
        "singleAgentWinsAreLosses": {
          "type": "boolean",
          "const": true
        },
        "invalidRunsCountAsLosses": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "lossRegistry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "countedAsLoss", "publicLabel"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "countedAsLoss": {
            "type": "boolean"
          },
          "publicLabel": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "humanBaselinePolicy": {
      "type": "object",
      "description": "Required for headlineEligible:true manifests.",
      "required": [
        "minimumDistinctHumans",
        "timedRuns",
        "blindReview",
        "publishAggregate"
      ],
      "additionalProperties": false,
      "properties": {
        "minimumDistinctHumans": {
          "type": "integer",
          "minimum": 3
        },
        "timedRuns": {
          "type": "boolean",
          "const": true
        },
        "blindReview": {
          "type": "boolean",
          "const": true
        },
        "publishAggregate": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "generatorPolicy": {
      "type": "object",
      "description": "Required for headlineEligible:true manifests. Describes the parametric-generator bar used for horizon claims.",
      "required": [
        "type",
        "minimumGeneratorCount",
        "difficultyKnobsRequired",
        "deterministicStateHash",
        "monotonicityEvidenceRequired"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "parametric_generators"
        },
        "minimumGeneratorCount": {
          "type": "integer",
          "minimum": 20
        },
        "difficultyKnobsRequired": {
          "type": "boolean",
          "const": true
        },
        "deterministicStateHash": {
          "type": "boolean",
          "const": true
        },
        "monotonicityEvidenceRequired": {
          "type": "boolean",
          "const": true
        },
        "canaryWorldCount": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "headlineEligible": {
      "type": "boolean",
      "description": "False for any public_validation or contamination-visible run."
    },
    "notes": {
      "type": "string"
    }
  }
}
