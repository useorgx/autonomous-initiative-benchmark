{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/sota-execution-ledger.schema.json",
  "title": "OrgX-Bench SOTA Execution Ledger",
  "description": "Release-level launch ledger binding every planned SOTA sweep execution unit to a scored, lost, blocked, launched, or planned state.",
  "type": "object",
  "required": ["contractVersion", "releaseId", "generatedAt", "source", "plannedJobCount", "accounting", "entries"],
  "additionalProperties": false,
  "properties": {
    "contractVersion": { "type": "string" },
    "releaseId": { "type": "string" },
    "generatedAt": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["releaseManifestPath", "registryPath"],
      "additionalProperties": false,
      "properties": {
        "releaseManifestPath": { "type": ["string", "null"] },
        "registryPath": { "type": ["string", "null"] }
      }
    },
    "plannedJobCount": { "type": "integer", "minimum": 0 },
    "accounting": {
      "type": "object",
      "required": ["planned", "launched", "scored", "lost", "blocked", "terminal", "unresolved", "total"],
      "additionalProperties": false,
      "properties": {
        "planned": { "type": "integer", "minimum": 0 },
        "launched": { "type": "integer", "minimum": 0 },
        "scored": { "type": "integer", "minimum": 0 },
        "lost": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "terminal": { "type": "integer", "minimum": 0 },
        "unresolved": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/ledgerEntry" }
    }
  },
  "$defs": {
    "ledgerEntry": {
      "type": "object",
      "required": ["kind", "status", "jobId", "releaseId", "worldId", "split", "arm"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["model", "human_baseline"]
        },
        "status": {
          "type": "string",
          "enum": ["planned", "launched", "scored", "lost", "blocked"]
        },
        "jobId": { "type": "string" },
        "releaseId": { "type": "string" },
        "worldId": { "type": "string" },
        "split": { "type": "string", "const": "private_holdout" },
        "model": { "type": "string" },
        "arm": { "type": "string" },
        "seedIndex": { "type": "integer", "minimum": 1 },
        "humanSlot": { "type": "integer", "minimum": 1 },
        "launchedAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "bundleRunId": { "type": "string" },
        "receiptHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "lossType": { "type": "string" },
        "countedAsLoss": { "type": "boolean" },
        "reason": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
