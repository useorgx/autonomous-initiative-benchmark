{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/outreach-target-plan.schema.json",
  "title": "OrgX-Bench SOTA Outreach Target Plan",
  "description": "Trackable outreach plan for methodology advice, paid human-baseline recruiting, independent replication, and outside reproduction.",
  "type": "object",
  "required": [
    "plan_version",
    "generated_at",
    "send_policy",
    "templates",
    "targets"
  ],
  "additionalProperties": false,
  "properties": {
    "plan_version": {
      "type": "string",
      "const": "sota_outreach_plan_v1"
    },
    "generated_at": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "send_policy": {
      "type": "object",
      "required": [
        "time_zone",
        "allowed_weekdays",
        "local_send_hour_start",
        "local_send_hour_end",
        "no_blasts",
        "max_first_wave_targets"
      ],
      "additionalProperties": false,
      "properties": {
        "time_zone": { "type": "string" },
        "allowed_weekdays": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_send_hour_start": { "type": "integer" },
        "local_send_hour_end": { "type": "integer" },
        "no_blasts": { "type": "boolean", "const": true },
        "max_first_wave_targets": { "type": "integer", "minimum": 1, "maximum": 10 },
        "max_per_send_window": { "type": "integer", "minimum": 1, "maximum": 10 },
        "send_spacing_minutes": { "type": "integer", "minimum": 10, "maximum": 180 },
        "follow_up_business_days": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 30 }
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/template" }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/target" }
    }
  },
  "$defs": {
    "template": {
      "type": "object",
      "required": ["template_id", "lane", "subject", "body"],
      "additionalProperties": false,
      "properties": {
        "template_id": { "type": "string" },
        "lane": { "$ref": "#/$defs/lane" },
        "subject": { "type": "string" },
        "body": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "required": [
        "target_id",
        "lane",
        "status",
        "priority",
        "contact",
        "rationale",
        "evidence_gaps",
        "ask",
        "template_id"
      ],
      "additionalProperties": false,
      "properties": {
        "target_id": { "type": "string" },
        "lane": { "$ref": "#/$defs/lane" },
        "status": {
          "type": "string",
          "enum": ["identified", "drafted", "queued", "sent", "replied", "declined", "scheduled", "completed"]
        },
        "priority": { "type": "string" },
        "wave": { "type": "integer", "minimum": 0 },
        "organization": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "contact": {
          "type": "object",
          "required": ["method"],
          "additionalProperties": false,
          "properties": {
            "method": {
              "type": "string",
              "enum": ["known_email", "public_email", "contact_form", "warm_intro_needed", "marketplace", "manual_research_needed"]
            },
            "value": { "type": "string" },
            "source_url": { "type": "string" }
          }
        },
        "rationale": { "type": "string" },
        "evidence_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ask": { "type": "string" },
        "template_id": { "type": "string" },
        "planned_send_window": {
          "type": "object",
          "required": ["start", "end"],
          "additionalProperties": false,
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" }
          }
        },
        "sent_at": { "type": "string" },
        "source_urls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "lane": {
      "type": "string",
      "enum": [
        "methodology_advisor",
        "paid_practitioner_baseline",
        "replication_partner",
        "stranger_reproduction_reviewer"
      ]
    }
  }
}
