{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/third-party-replication-evidence.schema.json",
  "title": "OrgX-Bench Third-Party Replication Evidence",
  "description": "Standalone evidence document for externally replicated OrgX-Bench rows before they are embedded in a headline bundle.",
  "type": "object",
  "required": ["protocol_version", "release_id", "generated_at", "rows"],
  "additionalProperties": false,
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "third_party_replication_evidence_v1"
    },
    "release_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string" },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "protocol_version",
          "party_id",
          "party_name",
          "world_id",
          "submission_id",
          "model_manifest_id",
          "run_manifest_id",
          "seed_commitment_hash",
          "signed_receipt_hash",
          "scorecard_hash",
          "replication_protocol_hash",
          "discrepancy_log_hash",
          "submitted_at",
          "scored_at",
          "agreement_within_ci",
          "discrepancies"
        ],
        "additionalProperties": false,
        "properties": {
          "protocol_version": {
            "type": "string",
            "const": "third_party_replication_v1"
          },
          "party_id": { "type": "string", "minLength": 1 },
          "party_name": { "type": "string", "minLength": 1 },
          "world_id": { "type": "string", "minLength": 1 },
          "submission_id": { "type": "string", "minLength": 1 },
          "model_manifest_id": { "type": "string", "minLength": 1 },
          "run_manifest_id": { "type": "string", "minLength": 1 },
          "seed_commitment_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "signed_receipt_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "scorecard_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "replication_protocol_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "discrepancy_log_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "submitted_at": { "type": "string" },
          "scored_at": { "type": "string" },
          "agreement_within_ci": { "type": "boolean" },
          "discrepancies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
