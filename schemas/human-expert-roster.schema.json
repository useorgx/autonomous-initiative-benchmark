{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useorgx.com/schemas/human-expert-roster.schema.json",
  "title": "OrgX-Bench Human Expert Roster",
  "description": "Versioned roster contract for timed expert baseline recruiting and assignment. This is scheduling evidence only; it is not a completed human baseline.",
  "type": "object",
  "required": [
    "roster_version",
    "protocol_version",
    "release_id",
    "generated_at",
    "compensation_disclosed",
    "experts"
  ],
  "additionalProperties": false,
  "properties": {
    "roster_version": {
      "type": "string",
      "const": "human_expert_roster_v1"
    },
    "protocol_version": {
      "type": "string",
      "const": "timed_expert_baseline_v2"
    },
    "release_id": {
      "type": ["string", "null"]
    },
    "generated_at": {
      "type": "string"
    },
    "compensation_disclosed": {
      "type": "boolean",
      "const": true
    },
    "notes": {
      "type": "string"
    },
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/expert" }
    }
  },
  "$defs": {
    "expert": {
      "type": "object",
      "required": [
        "expert_id",
        "domains",
        "max_sessions",
        "operator_profile_hash",
        "recruitment_channel",
        "compensation_disclosed",
        "private_validator_access",
        "conflict_attestation"
      ],
      "additionalProperties": false,
      "properties": {
        "expert_id": {
          "type": "string"
        },
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "max_sessions": {
          "type": "integer",
          "minimum": 1
        },
        "operator_profile_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "recruitment_channel": {
          "type": "string"
        },
        "compensation_disclosed": {
          "type": "boolean",
          "const": true
        },
        "private_validator_access": {
          "type": "boolean",
          "const": false
        },
        "due_at": {
          "type": ["string", "null"]
        },
        "conflict_attestation": {
          "type": "object",
          "required": [
            "no_orgx_employee",
            "no_private_validator_access",
            "no_prior_holdout_access"
          ],
          "additionalProperties": false,
          "properties": {
            "no_orgx_employee": {
              "type": "boolean",
              "const": true
            },
            "no_private_validator_access": {
              "type": "boolean",
              "const": true
            },
            "no_prior_holdout_access": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
